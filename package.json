{
  "name": "mtthorne-internal-ai-server",
  "version": "1.6.0",
  "private": true,
  "type": "module",
  "description": "Shared four-AI internal sidecar with PostgreSQL persistence, ArchE owner-source knowledge seeding, AVA operational governance, provider/cost gates, and authenticated ArchE bridge.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "AI_SERVER_PORT=8787 node src/server.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "health": "node src/cli.js health",
    "decision": "node src/cli.js decision",
    "queue": "node src/cli.js queue",
    "storage:migrate": "node scripts/migrate-json-to-postgres.mjs",
    "storage:migrate:overwrite": "node scripts/migrate-json-to-postgres.mjs --overwrite",
    "verify:registry": "node scripts/verify-public-registry.mjs",
    "predeploy": "npm run verify:registry && npm test",
    "seed:arche": "node scripts/seed-arche-knowledge.mjs",
    "seed:arche:no-overwrite": "node scripts/seed-arche-knowledge.mjs --no-overwrite",
    "verify:arche-knowledge": "node scripts/verify-arche-knowledge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "pg": "^8.21.0"
  }
}
