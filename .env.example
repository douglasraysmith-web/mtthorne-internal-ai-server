# Internal AI Server safe defaults
AI_SERVER_HOST=127.0.0.1
# AI_SERVER_PORT=8787  # optional local override only; leave unset on Railway so PORT is used
AI_PUBLIC_MODE=false
AI_ALLOW_PROVIDER_DISPATCH=false
AI_ALLOW_PROVIDER_NETWORK=false
AI_PROVIDER_DRY_RUN_ONLY=true
AI_ALLOW_ARCHE_PUSH=false
AI_STORAGE_DRIVER=json_file
AI_QUEUE_DRIVER=json_file

# Optional later, store in Railway env only, never commit real values
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AI_OWNER_APPROVAL_TOKEN=
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# v1.1.0 live connection readiness
ARCHE_BACKEND_URL=https://arche-backend-production.up.railway.app
ARCHE_FAST_CHAT_PATH=/api/arche-fast-chat
ARCHE_CHAT_PATH=/api/arche-chat
ARCHE_BRIDGE_TOKEN=
AI_ALLOWED_ORIGINS=https://mtthorne.com,https://www.mtthorne.com
AVA_RATE_LIMIT_PER_MINUTE=20
AVA_MAX_MESSAGE_CHARS=6000
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5
AI_OBJECT_STORAGE_DRIVER=local_manifest
AI_ALLOW_R2_WRITES=false

# Shared PostgreSQL storage for ArchE, AV.AI, V-Lock AI, and Janitor
# Use Railway's private DATABASE_URL reference. Never commit the real value.
AI_STORAGE_DRIVER=json_file
DATABASE_URL=
AI_POSTGRES_BOOTSTRAP_FROM_JSON=false
AI_POSTGRES_REQUIRE_CONNECTION=false
AI_POSTGRES_POOL_MAX=5
AI_DISABLE_LOCAL_STORAGE_BACKUP=false
AI_POSTGRES_SEED_DEFAULTS=true
